openwebui:
  image: my-branded-openwebui:latest   # ← now uses your custom built image
  build:
    context: ./openwebui-branding       # ← folder with your Dockerfile + assets
    dockerfile: Dockerfile
  container_name: openwebui
  restart: unless-stopped
  ports:
    - "3000:8080"
  volumes:
    - ./openwebui_data:/app/backend/data
  environment:
    - OPENAI_API_BASE_URL=http://192.168.122.1:8907/v1
    - OPENAI_API_KEY=none
    - WEBUI_AUTH=true
    - WEBUI_NAME=
    - WEBUI_BANNER_TEXT=
    - WEBUI_ADMIN_EMAIL=admin@localhost
    - WEBUI_ADMIN_PASSWORD=Passw0rd!123
    - OFFLINE_MODE=true
    - ENABLE_RAG_WEB_SEARCH=none
    - CONTENT_EXTRACT_ENGINE=none
    - ENABLE_LDAP=true
    - LDAP_SERVER_LABEL=
    - LDAP_SERVER_HOST=
    - LDAP_SERVER_PORT=389
    - LDAP_SEARCH_BASE=
    - LDAP_SEARCH_FILTER=(objectClass=person)
    - LDAP_ATTRIBUTE_FOR_USERNAME=uid
    - LDAP_ATTRIBUTE_FOR_MAIL=mail
    - LDAP_USE_TLS=false
    - DEFAULT_USER_ROLE=user
    - ENABLE_SIGNUP=true


---


FROM docker.io/openwebui/open-webui:0.8

# ─── Favicon & PWA icons (all variants) ──────────────────────────────────────
COPY icon.png /app/build/static/favicon.png
COPY icon.png /app/build/static/favicon.ico
COPY icon.png /app/build/static/favicon.svg
COPY icon.png /app/build/static/favicon-96x96.png
COPY icon.png /app/build/static/favicon-dark.png
COPY icon.png /app/build/static/apple-touch-icon.png
COPY icon.png /app/build/static/splash.png
COPY icon.png /app/build/static/splash-dark.png
COPY icon.png /app/build/static/web-app-manifest-192x192.png
COPY icon.png /app/build/static/web-app-manifest-512x512.png

# ─── Sidebar logo ─────────────────────────────────────────────────────────────
COPY logo.png /app/build/static/logo.png

# ─── Replace all "Open WebUI" text in built frontend files ───────────────────
RUN find /app/build -type f \( -name "*.js" -o -name "*.html" \) \
    -exec sed -i 's/Open WebUI/C-DACS AI/g' {} + || true && \
    find /app/build -type f \( -name "*.js" -o -name "*.html" \) \
    -exec sed -i 's/OpenWebUI/CDACSAI/g' {} + || true

# ─── Inject custom CSS ────────────────────────────────────────────────────────
COPY custom.css /app/build/static/custom.css



---


/* ── Hide the default Open WebUI SVG logo in the sidebar ── */
nav img[alt="Open WebUI"],
.sidebar img,
img[src*="favicon"] {
  display: none !important;
}

/* ── Inject your logo.png as sidebar brand image ── */
nav a[href="/"] {
  background-image: url('/static/logo.png') !important;
  background-size: contain !important;
  background-repeat: no-repeat !important;
  background-position: left center !important;
  display: block !important;
  width: 180px !important;
  height: 48px !important;
  min-height: 48px !important;
}

/* ── Hide the text label next to the logo if needed ── */
nav a[href="/"] span {
  display: none !important;
}

/* ─── Optional: accent color to match C-DACS branding ─── */
:root {
  --color-primary: #0057a8;
}

button[type="submit"],
#send-message-button {
  background-color: var(--color-primary) !important;
}

[role="switch"][aria-checked="true"] {
  background-color: var(--color-primary) !important;
}

/* ── FIXED: Replace sidebar favicon with your logo ── */
img.sidebar-new-chat-icon {
  content: url('/static/logo.png') !important;
  width: 140px !important;
  height: 36px !important;
  max-width: none !important;
  border-radius: 0 !important;
  object-fit: contain !important;
}



---
services:
  vllm:
    image: vllm/vllm-openai:v0.19.0
    container_name: vllm
    restart: unless-stopped

    # GPU access via CDI (both L40S cards).
    # Equivalent to: --device nvidia.com/gpu=0 --device nvidia.com/gpu=1
    devices:
      - nvidia.com/gpu=0
      - nvidia.com/gpu=1

    # Equivalent to: --security-opt=label=disable
    security_opt:
      - label=disable

    # Equivalent to: --shm-size=10.24gb
    shm_size: "10.24gb"

    # Equivalent to: --add-host=host.docker.internal:host-gateway
    extra_hosts:
      - "host.docker.internal:host-gateway"

    environment:
      - CUDA_DEVICE_ORDER=PCI_BUS_ID

    # host:container  -> 8907 on host maps to 8000 in container
    ports:
      - "8907:8000"

    # Model directory bind mount. The :z relabel is what fixes the
    # SELinux/permission issue so the container can read the models.
    volumes:
      - /var/data/llm-models:/data:z

    # vLLM server arguments (everything after the image in podman run)
    command:
      - --model
      - /data/Qwen_Qwen3-Coder-30B-A3B-Instruct
      - --served-model-name
      - Qwen/Qwen_Qwen3-Coder-30B-A3B-Instruct
      - --tensor-parallel-size
      - "2"
      - --dtype
      - float16
      - --gpu-memory-utilization
      - "0.98"
      - --max-model-len
      - "4096"
      - --max-num-seqs
      - "16"
      - --max-num-batched-tokens
      - "4096"
      - --enforce-eager



1. List models (confirms it's up and serving):


curl -s http://localhost:8907/v1/models | jq
2. Send a test chat completion:


curl -s http://localhost:8907/v1/chat/completions \
  -H "Content-Type: application/json" \
  -d '{
    "model": "Qwen/Qwen_Qwen3-Coder-30B-A3B-Instruct",
    "messages": [{"role": "user", "content": "Say hello in one word."}],
    "max_tokens": 20
  }' | jq
If you're on the host running podman (), use localhost. If running from another machine, swap in that host's IP.

If you want to test it through LiteLLM instead (to verify the full chain you just wired up):


curl -s http://localhost:9001/v1/chat/completions \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer sk-admin-master-key-change-me" \
  -d '{
    "model": "qwen3-30b",
    "messages": [{"role": "user", "content": "Say hello in one word."}],
    "max_tokens": 20
  }' | jq





1. Health check (the endpoint used in the compose healthcheck):


curl -s http://localhost:9001/health | jq
2. List models LiteLLM has configured:


curl -s http://localhost:9001/v1/models \
  -H "Authorization: Bearer sk-admin-master-key-change-me" | jq
3. Chat completion through LiteLLM → vLLM (full chain test):


curl -s http://localhost:9001/v1/chat/completions \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer sk-admin-master-key-change-me" \
  -d '{
    "model": "qwen3-30b",
    "messages": [{"role": "user", "content": "Say hello in one word."}],
    "max_tokens": 20
  }' | jq
4. Detailed health check (verifies LiteLLM can actually reach its backend, vLLM):


curl -s http://localhost:9001/health/readiness \
  -H "Authorization: Bearer sk-admin-master-key-change-me" | jq








